# ===========================================
# AI Model Configuration
# ===========================================

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=example
# carl.schulz@asurion
# Anthropic (Claude)
ANTHROPIC_API_KEY=example-here

# Google (Gemini)
GOOGLE_AI_API_KEY=example
#carlsdesigns
# Default AI provider: openai | anthropic | google
AI_PROVIDER=openai

# Default model per provider
OPENAI_MODEL=gpt-4-turbo
ANTHROPIC_MODEL=claude-3-opus-20240229
GOOGLE_MODEL=gemini-pro

# ===========================================
# ElevenLabs Voice Configuration
# ===========================================

ELEVENLABS_API_KEY=example
#carlsdesigns $5/mo
# Voice ID for child-friendly narration
ELEVENLABS_VOICE_ID=mHX7OoPk2G45VMAuinIt

# Voice settings
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# ===========================================
# Database Configuration
# ===========================================

# SQLite (default for simplicity)
DATABASE_URL=file:./data/learning.db

# Or PostgreSQL for production
# DATABASE_URL=postgresql://user:password@localhost:5432/bing_ding_learning

# ===========================================
# Application Settings
# ===========================================

NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session secret for authentication
SESSION_SECRET=your-secure-session-secret-here

# ===========================================
# Feature Flags
# ===========================================

ENABLE_VOICE_FEEDBACK=true
ENABLE_AI_HINTS=true
ENABLE_PROGRESS_REPORTS=true
